// Minimal LFR case corresponding to a REACTION CHAMBER.
// Matches the MINT primitive `Chamber ...` in QuickTest/default/MINT/ReactionChamber.mint.
// Fluid flows into the chamber, undergoes an incubation / reaction step
// (mapped to the `~` operator), and flows out. #MAP directs the technology
// mapper to realize `~` as a physical reaction chamber.
module ReactionChamber(
    finput in_1,
    foutput out_1
);
    #MAP "CHAMBER" "~"
    assign out_1 = ~in_1;
endmodule
