{
  "_LFR_filename": "picoinjector.lfr",
  "_LFR_source": [
    "// Minimal LFR case corresponding to a PICOINJECTOR.",
    "// Matches the MINT primitive in QuickTest/default/MINT/picoinjector.mint.",
    "// A passing droplet stream `droplet_in` is merged with a reagent stream",
    "// `inject_in` when the electrode control signal `c` is asserted, yielding",
    "// the picoinjected droplet stream `droplet_out`.",
    "module picoinjector(",
    "    finput droplet_in, inject_in,",
    "    foutput droplet_out,",
    "    control c",
    ");",
    "    distribute@(c)",
    "    begin",
    "        if (c == 1)",
    "        begin",
    "            droplet_out <= droplet_in + inject_in;",
    "        end",
    "        else",
    "        begin",
    "            droplet_out <= droplet_in;",
    "        end",
    "    end",
    "endmodule"
  ],
  "_MINT_filename": "picoinjector.mint",
  "_MINT_source": [
    "DEVICE picoinjector",
    "",
    "LAYER FLOW",
    "",
    "PICOINJECTOR picoinjector componentSpacing=1000 height=250 width=10000 injectorWidth=2000 injectorLength=3000 dropletWidhth=800 nozzleWidth=400 nozzleLength=400 electrodeDistance=800 electrodeWidth=800 electrodeLength=3000 rotation=0;",
    "",
    "END LAYER"
  ],
